# Project Environment Variables

# Backend
API_PORT=8000
API_HOST=0.0.0.0

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# Azure ML (Optional)
AZURE_TENANT_ID=your_tenant_id
